{
    "swagger": "2.0",
    "info": {
        "description": "校友场地预约系统的后端API服务",
        "title": "预约系统 API",
        "contact": {},
        "version": "2.0"
    },
    "host": "localhost:8081",
    "basePath": "/api/v2",
    "paths": {
        "/reservation/my": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "获取当前登录用户的所有预约订单（包含各时段明细），需要JWT认证",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "预约管理"
                ],
                "summary": "获取我的预约列表",
                "parameters": [
                    {
                        "type": "string",
                        "default": "Bearer",
                        "description": "Bearer JWT令牌",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "查询成功",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/internal_reservation.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/internal_reservation.OrderResp"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "401": {
                        "description": "未授权",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    },
                    "500": {
                        "description": "服务器内部错误",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    }
                }
            }
        },
        "/reservation/occupied": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "查询指定日期已被预约占用的时间段，需要JWT认证",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "预约管理"
                ],
                "summary": "获取已占用时间段",
                "parameters": [
                    {
                        "type": "string",
                        "default": "Bearer",
                        "description": "Bearer JWT令牌",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "example": "2026-01-01",
                        "description": "查询日期(格式: 2026-01-01)",
                        "name": "date",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "查询成功",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/internal_reservation.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/internal_reservation.TimeSlotResp"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    }
                }
            }
        },
        "/reservation/submit": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "用户提交场地预约申请，支持一次提交1~4个时间段，需要JWT认证",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "预约管理"
                ],
                "summary": "提交预约申请（支持多时段）",
                "parameters": [
                    {
                        "type": "string",
                        "default": "Bearer",
                        "description": "Bearer JWT令牌",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "预约提交请求（含多个时间段）",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.SubmitReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "预约申请提交成功",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/internal_reservation.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/internal_reservation.OrderResp"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    },
                    "401": {
                        "description": "未授权",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    }
                }
            }
        },
        "/reservation/{id}": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "取消指定的预约订单（取消所有关联的时段），仅预约人本人可操作，需要JWT认证",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "预约管理"
                ],
                "summary": "取消预约",
                "parameters": [
                    {
                        "type": "string",
                        "default": "Bearer",
                        "description": "Bearer JWT令牌",
                        "name": "Authorization",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "example": 1,
                        "description": "订单ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "取消成功",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    },
                    "400": {
                        "description": "请求参数错误",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    },
                    "401": {
                        "description": "未授权",
                        "schema": {
                            "$ref": "#/definitions/internal_reservation.Response"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_reservation.OrderResp": {
            "type": "object",
            "properties": {
                "alumni_association": {
                    "type": "string",
                    "example": "土木与交通工程学院校友会"
                },
                "applicant_name": {
                    "type": "string",
                    "example": "张三"
                },
                "created_at": {
                    "type": "string",
                    "example": "2026-01-01 08:30"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "major": {
                    "type": "string",
                    "example": "建筑系"
                },
                "order_no": {
                    "type": "string",
                    "example": "R202601010900001234"
                },
                "phone": {
                    "type": "string",
                    "example": "13800138000"
                },
                "reason": {
                    "type": "string",
                    "example": "智慧城市讲座"
                },
                "slots": {
                    "description": "时段明细列表",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/internal_reservation.SlotResp"
                    }
                },
                "status": {
                    "type": "integer",
                    "example": 0
                },
                "status_text": {
                    "type": "string",
                    "example": "待审核"
                },
                "total_slots": {
                    "type": "integer",
                    "example": 2
                },
                "year": {
                    "type": "integer",
                    "example": 2000
                }
            }
        },
        "internal_reservation.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "data": {},
                "msg": {
                    "type": "string",
                    "example": "success"
                }
            }
        },
        "internal_reservation.SlotResp": {
            "type": "object",
            "properties": {
                "end_time": {
                    "type": "string",
                    "example": "2026-01-01 10:00"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "start_time": {
                    "type": "string",
                    "example": "2026-01-01 08:00"
                },
                "status": {
                    "type": "integer",
                    "example": 0
                },
                "status_text": {
                    "type": "string",
                    "example": "待审核"
                }
            }
        },
        "internal_reservation.SubmitReq": {
            "type": "object",
            "required": [
                "alumni_association",
                "applicant_name",
                "major",
                "phone",
                "reason",
                "slots",
                "year"
            ],
            "properties": {
                "alumni_association": {
                    "type": "string",
                    "example": "土木与交通工程学院校友会"
                },
                "applicant_name": {
                    "type": "string",
                    "example": "张三"
                },
                "major": {
                    "type": "string",
                    "example": "建筑系"
                },
                "phone": {
                    "type": "string",
                    "example": "13800138000"
                },
                "reason": {
                    "type": "string",
                    "maxLength": 500,
                    "example": "智慧城市讲座"
                },
                "slots": {
                    "description": "预约时间段列表（1~4个）",
                    "type": "array",
                    "maxItems": 4,
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/internal_reservation.TimeSlotReq"
                    }
                },
                "year": {
                    "type": "integer",
                    "example": 2000
                }
            }
        },
        "internal_reservation.TimeSlotReq": {
            "type": "object",
            "required": [
                "end_time",
                "start_time"
            ],
            "properties": {
                "end_time": {
                    "description": "结束时间",
                    "type": "string",
                    "example": "2026-01-01 10:00:00"
                },
                "start_time": {
                    "description": "开始时间",
                    "type": "string",
                    "example": "2026-01-01 08:00:00"
                }
            }
        },
        "internal_reservation.TimeSlotResp": {
            "type": "object",
            "properties": {
                "end_time": {
                    "type": "string",
                    "example": "2026-01-01 11:00"
                },
                "start_time": {
                    "type": "string",
                    "example": "2026-01-01 09:00"
                },
                "status": {
                    "description": "pending待审核 / approved已通过",
                    "type": "string",
                    "example": "pending"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "JWT Bearer令牌认证，格式: Bearer token",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}