# /root/workspace/reservation_sys_go/deploy/nginx/nginx.conf

# 下面是全局配置块

# 自动根据 CPU 核心数设置工作进程
# Nginx 使用 "主进程 + 工作进程" 的模式
worker_processes auto; 

# 错误日志路径，"warn" 表示只记录警告及以上级别的日志
error_log /var/log/nginx/error.log warn;

# TODO 学习一下 Nginx 进程管理
# 存储 Nginx 主进程 PID 的文件路径，用于进程管理
pid /var/run/nginx.pid;

# 下面是 events 配置块
events {
    # 每个工作进程能同时处理多最大连接数量
    worker_connections 1024;
}


# 喜爱那是 HTTP 配置块

http {
    # TODO 学习一下下面这些映射具体是指什么东西
    # 引入 MIME 类型映射文件
    include /etc/nginx/mime.types;
    # 对于无法识别的文件类型，默认使用 application/octet-stream(二进制流)，浏览器会出发下载而不是显示
    default_type application/octet-stream;

    # 日志格式定义
    # remote_addr: 客户端 IP 地址
    # remote_user: 客户端用户名
    # time_local: 本地时间
    # request: 客户端请求方法和路径
    # status: 响应状态码
    # body_bytes_sent: 相应体字节数
    # http_referer: 请求来源页面
    # http_user_agent: 浏览器信息
    # http_x_forwarded_for: 代理链 IP
    log_format main '$remote_addr - $remote_user [$time_local] "$request" '
                    '$status $body_bytes_sent "$http_referer" '
                    '"$http_user_agent" "$http_x_forwarded_for"';

    # 配置日志存放路径
    access_log /var/log/nginx/access.log main;

    # 启用 Linux 的 sendfile() 系统调用，数据直接从文件系统传输到网络套接字，不需要经过用户空间，提高静态文件传输效率
    sendfile on;
    # 保持连接的超时时间(秒)，客户端建立连接后，65秒内可以复用同一个连接发送多个请求，减少 TCP 握手开销
    keepalive_timeout 65;
    
    # Gzip 压缩
    # 启动 gzip 压缩
    gzip on;
    # 制定那些 MIME 类型需要压缩
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;

    # 上游服务器定义
    # upstream 用来定义一组后端服务器，用于负载均衡和反向代理
    # upstream 相当于给后端服务定义一个名字，方便使用
    # 负载均衡: 
    # upstream v1_backend {
    #       server v1-service-1:8080 weight=3;  # 权重 3，接收 75% 流量
    #       server v1-service-2:8080 weight=1;  # 权重 1，接收 25% 流量
    # }
    
    upstream v1_backend {
        server v1-service:8080;
    }

    upstream v2_backend {
        server v2-service:8081;
    }

    # upstream v3_backend {
    #     server v3-service:8082;
    # }

    server {
        listen 80;
        server_name locolhost mytestsite.cloud www.mytestsite.cloud;

        # 微信服务器消息入口
        location /wx {
            proxy_pass http://v1_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        # 微信 OAuth 回调
        location /api/v1/auth {
            proxy_pass http://v1_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        # 预约页面 - 首页
        location / {
            proxy_pass http://v2_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        # 预约 API
        location /api/v2/ {
            proxy_pass http://v2_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        # 静态资源
        location /static/v2 {
            proxy_pass http://v2_backend;
            proxy_set_header Host $host;
        }

        # 管理后台（待 v3 模块开发完成后启用）
        # location /admin/ {
        #     proxy_pass http://v3_backend;
        #     proxy_set_header Host $host;
        #     proxy_set_header X-Real-IP $remote_addr;
        #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # }

        # location /api/v3/ {
        #     proxy_pass http://v3_backend;
        #     proxy_set_header Host $host;
        #     proxy_set_header X-Real-IP $remote_addr;
        #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # }

        # 健康检查
        location /health {
            return 200 "OK";
            add_header Content-Type text/plain;
        }
    }
}
